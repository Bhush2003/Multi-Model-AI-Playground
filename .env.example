# Copy this file to .env and fill in real values.
# Used by docker-compose to inject secrets into the backend service.
# NEVER commit .env to source control.

# Required to sign JWTs — generate with: openssl rand -hex 32
JWT_SECRET=

# AI Provider Keys
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
ANTHROPIC_API_KEY=sk-ant-...
